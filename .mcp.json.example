{
  "mcpServers": {
    "dali": {
      "command": "node",
      "args": ["<path-to-dali-memory-openclaw>/dist/index.js"],
      "env": {
        "DALI_DB_PATH": "~/.claude/dali/dali.db",
        "OLLAMA_BASE_URL": "http://localhost:11434",
        "OLLAMA_MODEL": "nomic-embed-text"
      }
    }
  }
}
